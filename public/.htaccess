<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Keep API requests available for the backend rather than serving the SPA.
  RewriteRule ^api(?:/|$) - [L]

  # Serve deployed assets directly and send client-side routes to React.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>
